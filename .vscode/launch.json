{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "调试 data-agent 组装工厂 web ",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/backend/tests/service_agent/test-data-agent/run_data_agent_web.py",
      "python": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "env": {
        "TABLERAG_CONFIG": "D:\\A-PythonWork\\AOpenGithub\\deer-flow\\tablerag.yaml",
        "TABLERAG_MCP_INDEX_DSN": "postgresql://postgres:postgres@127.0.0.1:55433/text2sql",
        "TABLERAG_MCP_SOURCE_DSN": "postgresql://postgres:postgres@127.0.0.1:55433/text2sql",
        "DATA_AGENT_MYSQL_DSN": "mysql+pymysql://root:root%40123456@127.0.0.1:3308/text2sql"
      }
    },
    {
      "name": "DeerFlow: 调试 Gateway",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
      "debugAdapterPython": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
      "debugLauncherPython": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
      "module": "uvicorn",
      "args": [
        "app.gateway.app:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8001"
      ],
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUTF8": "1",
        "PYTHONPATH": ".",
        "DEER_FLOW_PROJECT_ROOT": "${workspaceFolder}",
        "DEER_FLOW_HOME": "${workspaceFolder}/backend/.deer-flow",
        "DEER_FLOW_CONFIG_PATH": "${workspaceFolder}/config.yaml",
        "DEER_FLOW_EXTENSIONS_CONFIG_PATH": "${workspaceFolder}/extensions_config.json",
        "DEER_FLOW_STREAM_BRIDGE_REDIS_URL": "redis://localhost:6379/0",
        "GATEWAY_CORS_ORIGINS": "http://localhost:3000,http://127.0.0.1:3000"
      },
      "console": "integratedTerminal",
      "justMyCode": false,
      "subProcess": true
    }
  ]
}
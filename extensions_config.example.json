{
  "mcpInterceptors": [],
  "mcpServers": {
    "github": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_TOKEN"
      },
      "tool_call_timeout": 60,
      "description": "GitHub MCP server for repository operations"
    },
    "postgres": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://localhost/mydb"
      ],
      "env": {},
      "description": "PostgreSQL database access"
    },
    "tablerag": {
      "enabled": false,
      "type": "stdio",
      "command": "python",
      "args": [
        "-m",
        "table_rag.mcp",
        "--transport",
        "stdio"
      ],
      "env": {
        "TABLERAG_MCP_CONFIG": "$TABLERAG_CONFIG",
        "TABLERAG_MCP_ALLOW_INITIALIZE": "false",
        "TABLERAG_MCP_ALLOW_SYNC_VALUES": "false"
      },
      "tool_call_timeout": 60,
      "description": "TableRAG MCP server for DataAgent Text2SQL context retrieval"
    }
  },
  "skills": {}
}

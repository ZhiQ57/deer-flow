{
  "mcpInterceptors": [],
  "mcpServers": {
    "github": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_TOKEN"
      },
      "tool_call_timeout": 60,
      "description": "GitHub MCP server for repository operations"
    },
    "postgres": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://localhost/mydb"
      ],
      "env": {},
      "description": "PostgreSQL database access",
      "routing": {
        "mode": "prefer",
        "priority": 50,
        "keywords": [
          "database",
          "SQL",
          "table",
          "订单",
          "用户"
        ]
      },
      "tools": {
        "query": {
          "routing": {
            "mode": "prefer",
            "priority": 100,
            "keywords": [
              "查库",
              "订单表",
              "指标"
            ]
          }
        }
      }
    },
    "tablerag": {
      "enabled": false,
      "type": "stdio",
      "command": "python",
      "args": [
        "-m",
        "table_rag.mcp",
        "--transport",
        "stdio"
      ],
      "env": {
        "TABLERAG_MCP_CONFIG": "$TABLERAG_CONFIG",
        "TABLERAG_MCP_ALLOW_INITIALIZE": "false",
        "TABLERAG_MCP_ALLOW_SYNC_VALUES": "false"
      },
      "tool_call_timeout": 60,
      "description": "TableRAG MCP server for DataAgent Text2SQL context retrieval",
      "routing": {
        "mode": "prefer",
        "priority": 90,
        "keywords": [
          "Text2SQL",
          "NL2SQL",
          "schema",
          "table_rag",
          "数据表",
          "字段",
          "查库"
        ]
      }
    }
  },
  "skills": {}
}
